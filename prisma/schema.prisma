// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id             String           @id @default(uuid())
  firstName      String
  lastName       String
  username       String           @unique
  phoneNo        String           @unique
  gender         Gender
  location       String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  lastLogin      DateTime?
  vehichles      Vehicle[]
  reservations   Reservation[]
  checkIns       CheckIn[]
  incidentReport IncidentReport[]
}

enum Gender {
  MALE
  FEMALE
}

model ParkingAvenue {
  id              String             @id @default(uuid())
  name            String             @unique
  address         String
  latitude        Float
  longitude       Float
  ownerId         String
  owner           ParkingAvenueOwner @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  workingHrs      String
  hourlyRate      Float
  type            ParkingAvenueType  @default(OFF_STREET)
  totalSpots      Int
  status          PARKINGSTATUS
  currentSpots    Int
  legalDoc        String
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  reservations    Reservation[]
  approvalStatus  ApprovalStatus     @default(UNDERREVIEW)
  rejectionReason String?
  subCity         SUBCITY

  checkIns           CheckIn[]
  warden             Warden[]
  parkingAvenueImage ParkingAvenueImage[]
  occupancyLogs      OccupancyLog[]
  incidentReport     IncidentReport[]

  endLatitude    Float? // Optional, for ON_STREET range
  endLongitude   Float? // Optional, for ON_STREET range
}

enum SUBCITY {
  ADDISKETEMA
  AKAKYKALITI
  ARADA
  BOLE
  GULLELE
  KIRKOS
  KOLFEKERANIO
  LIDETA
  NIFASSILKLAFTO
  YEKA
  LEMIKURA
}

enum PARKINGSTATUS {
  OPEN
  CLOSED
  MAINTENANCE
}

enum ParkingAvenueType {
  ON_STREET
  OFF_STREET

  @@map("PARKINGAVENUETYPE")
}

model Admin {
  id        String    @id @default(uuid())
  username  String    @unique
  password  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  lastLogin DateTime?
}

model ParkingAvenueOwner {
  id               String          @id @default(uuid())
  firstName        String
  lastName         String
  username         String          @unique
  password         String
  phoneNo          String          @unique
  email            String          @unique
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  lastLogin        DateTime?
  isVerified       ApprovalStatus  @default(UNDERREVIEW)
  parkingAvenues   ParkingAvenue[]
  personalId       String
  rejectionReason  String?
  resetToken       String?
  resetTokenExpiry DateTime?
  isCreatedByAdmin Boolean         @default(false)
}

model Reservation {
  id                   String   @id @default(uuid())
  bookingRef           String   @unique
  startTime            DateTime
  endTime              DateTime
  durationHours        Int
  totalPrice           Float
  status               String   @default("PENDING") // PENDING, CONFIRMED, CANCELLED, FULLFILLED
  qrCode               String?
  transactionReference String?  @unique
  plateNumber          String   @unique
  reminderSent         Boolean  @default(false)

  userId          String
  user            Customer      @relation(fields: [userId], references: [id])
  parkingAvenueId String
  parkingAvenue   ParkingAvenue @relation(fields: [parkingAvenueId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vehicle {
  id           Int      @id @default(autoincrement())
  licensePlate String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  ownerId      String
  owner        Customer @relation(fields: [ownerId], references: [id])

  @@unique([ownerId, licensePlate])
}

model CheckIn {
  id              String        @id @default(uuid())
  licensePlate    String        @unique
  parkingAvenueId String
  parkingAvenue   ParkingAvenue @relation(fields: [parkingAvenueId], references: [id])
  userId          String?
  user            Customer?     @relation(fields: [userId], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Temp {
  id             String    @id @default(uuid())
  firstName      String
  lastName       String
  username       String    @unique
  phoneNo        String    @unique
  gender         Gender
  location       String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lastLogin      DateTime?
  verificationId String
  code           String    @unique
}

model Warden {
  id              String           @id @default(uuid())
  firstName       String
  lastName        String
  username        String           @unique
  phoneNo         String           @unique
  gender          Gender
  residenceArea   String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  lastLogin       DateTime?
  wardenStatus    WardenStatus     @default(OFFDUTY)
  parkingAvenueId String
  parkingAvenue   ParkingAvenue    @relation(fields: [parkingAvenueId], references: [id])
  incidentReport  IncidentReport[]
}

enum WardenStatus {
  ONDUTY
  OFFDUTY
}

enum ApprovalStatus {
  UNDERREVIEW
  APPROVED
  REJECTED
}

model ParkingAvenueImage {
  id              String        @id @default(uuid())
  parkingAvenueId String
  parkingAvenue   ParkingAvenue @relation(fields: [parkingAvenueId], references: [id])
  photosUrl       String
}

model OccupancyLog {
  id        String   @id @default(uuid())
  timestamp DateTime @default(now())

  parkingAvenueId String
  parkingAvenue   ParkingAvenue @relation(fields: [parkingAvenueId], references: [id], onDelete: Cascade)

  hour      Int
  dayOfWeek Int
  isWeekend Int

  totalSpots    Int
  currentSpots  Int
  occupancyRate Float

  @@index([parkingAvenueId, timestamp])
}

model IncidentReport {
  id        String         @id @default(uuid())
  category  ReportCategory
  reason    String
  createdAt DateTime       @default(now())

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])
  wardenId   String?
  warden     Warden?   @relation(fields: [wardenId], references: [id])

  parkingAvenueId String
  parkingAvenue   ParkingAvenue @relation(fields: [parkingAvenueId], references: [id])
}

enum ReportCategory {
  ACCIDENT
  THEFT
  PARKINGSPACETAKEN
  OTHER
}
