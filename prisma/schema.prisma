// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
  
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")

}

model User {
  id	                  String         @id @default(uuid())
  firstName	            String	
  lastName	            String	
  phoneNo               String	       @unique
  password              String
  gender                Gender
  location              String
  createdAt	            DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  lastLogin             DateTime?
  // bookings	    Booking[]
  // notifications Notification[]
  // favorites    Favorites[]
  // @@index([location]) // For location filters
}

enum Gender {
  MALE
  FEMALE
}

model ParkingAvenue {
  id	           String                   @id @default(uuid())
  name           String                   @unique
  address        String                   @unique
  latitude       String                   @unique
  longitude      String                   @unique 
  ownerId        String           
  owner          ParkingAvenueOwner       @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  workingHrs	   String
  totalSpots	   Int
  status	       PARKINGSTATUS
  currentSpots	 Int
  photoUrl	     String
  createdAt	     DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
}

enum PARKINGSTATUS {
  OPEN
  CLOSED
  MAINTENANCE
}

model Admin {
  id	           String          @id @default(uuid())
  username       String          @unique
  password       String
  createdAt	     DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model ParkingAvenueOwner {
  id	           String          @id @default(uuid())
  username       String          @unique
  password       String
  createdAt	     DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  parkingAvenues ParkingAvenue[]
}