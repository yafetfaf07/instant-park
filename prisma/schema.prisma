// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id        String    @id @default(uuid())
  firstName String
  lastName  String
  username  String    @unique
  phoneNo   String    @unique
  password  String
  gender    Gender
  location  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  lastLogin DateTime?
  // bookings	    Booking[]
  // notifications Notification[]
  // favorites    Favorites[]
  // @@index([location]) // For location filters

  reservations Reservation[]
}

enum Gender {
  MALE
  FEMALE
}

model ParkingAvenue {
  id           String             @id @default(uuid())
  name         String             @unique
  address      String             @unique
  latitude     Float
  longitude    Float
  ownerId      String
  owner        ParkingAvenueOwner @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  workingHrs   String
  hourlyRate   Float
  totalSpots   Int
  status       PARKINGSTATUS
  currentSpots Int
  photoUrl     String
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  reservations Reservation[]
}

enum PARKINGSTATUS {
  OPEN
  CLOSED
  MAINTENANCE
}

model Admin {
  id        String    @id @default(uuid())
  username  String    @unique
  password  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  lastLogin DateTime?
}

model ParkingAvenueOwner {
  id             String          @id @default(uuid())
  firstName      String
  lastName       String
  username       String          @unique
  password       String
  phoneNo        String          @unique
  email          String          @unique
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  lastLogin      DateTime?
  isVerified     Boolean         @default(false)
  parkingAvenues ParkingAvenue[]
}

model Reservation {
  id                   String   @id @default(uuid())
  bookingRef           String   @unique
  startTime            DateTime
  endTime              DateTime
  durationHours        Int
  totalPrice           Float
  status               String   @default("PENDING") // PENDING, CONFIRMED, CANCELLED
  qrCode               String?
  transactionReference String?  @unique

  userId          String
  user            Customer      @relation(fields: [userId], references: [id])
  parkingAvenueId String
  parkingAvenue   ParkingAvenue @relation(fields: [parkingAvenueId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
